{
  "manifest_version": 3,
  "name": "SwissMedical CRM - WhatsApp Notificaciones",
  "version": "1.0.0",
  "description": "Notificaciones automáticas para mensajes de WhatsApp programados en tu CRM",
  "permissions": [
    "notifications",
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "https://firestore.googleapis.com/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "⏰ WhatsApp Notificaciones"
  }
}
